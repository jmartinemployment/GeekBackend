@page
@model GeekAPI.Pages.Account.TwoFactor.IndexModel
<h1>Two-factor authentication</h1>
<p class="muted">Enter the 6-digit code from your authenticator app.</p>
<form method="post">
    <input type="hidden" asp-for="Input.SessionCode" />
    <input type="hidden" asp-for="Input.ReturnUrl" />
    <label asp-for="Input.TotpCode">Authentication code</label>
    <input asp-for="Input.TotpCode" inputmode="numeric" autocomplete="one-time-code" maxlength="8" />
    <label>
        <input asp-for="Input.UseRecoveryCode" type="checkbox" /> Use recovery code
    </label>
    <label asp-for="Input.RecoveryCode">Recovery code</label>
    <input asp-for="Input.RecoveryCode" />
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <p class="error">@Model.ErrorMessage</p>
    }
    <button type="submit">Verify</button>
</form>

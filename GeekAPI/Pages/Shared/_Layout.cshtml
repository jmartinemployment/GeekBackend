<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Geek Sign In</title>
    <style>
        :root { color-scheme: light dark; --bg: #0f1419; --card: #1a2332; --text: #e7ecf3; --accent: #3b82f6; --border: #2d3a4f; }
        body { font-family: system-ui, sans-serif; background: var(--bg); color: var(--text); margin: 0; min-height: 100vh; display: grid; place-items: center; }
        .card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 2rem; width: min(420px, 92vw); box-shadow: 0 12px 40px rgba(0,0,0,.35); }
        h1 { margin: 0 0 .5rem; font-size: 1.5rem; }
        label { display: block; margin: 1rem 0 .35rem; font-size: .9rem; }
        input { width: 100%; box-sizing: border-box; padding: .65rem .75rem; border-radius: 8px; border: 1px solid var(--border); background: #0d1117; color: var(--text); }
        button { margin-top: 1.25rem; width: 100%; padding: .75rem; border: 0; border-radius: 8px; background: var(--accent); color: #fff; font-weight: 600; cursor: pointer; }
        .error { color: #f87171; margin-top: .75rem; font-size: .9rem; }
        .muted { color: #94a3b8; font-size: .85rem; }
    </style>
</head>
<body>
    <main class="card">@RenderBody()</main>
</body>
</html>

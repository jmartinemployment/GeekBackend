# GeekRepository
DATABASE_URL=postgresql://user:password@localhost:5432/geekbackend
# Interim local/CI only — do not use in production (see Architecture.md)
# REPO_API_KEY=local-dev-only

# GeekAPI
PORT=8080
ASPNETCORE_ENVIRONMENT=Development
REPO_URL=http://localhost:5050
GEEK_BACKEND_API_KEY=change-me-api-key
CORS_ORIGINS=http://localhost:3000,https://www.geekatyourspot.com,http://127.0.0.1

# Target S2S (when authorization server is deployed)
# AUTH_SERVER_URL=https://auth.geekatyourspot.com
# GEEKAPI_CLIENT_ID=geekapi
# GEEKAPI_CLIENT_SECRET=

# Optional
BCRYPT_WORK_FACTOR=12

# Integration tests
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/geekbackend_test
TEST_REPO_URL=http://127.0.0.1:5050

# Database connection (replace with your Supabase connection string)
DATABASE_URL=postgresql://user:password@localhost:5432/geekbackend

# API Port (optional, defaults to 8080)
PORT=8080

# GeekAPI — comma-separated browser origins (Geek SEO frontend)
# CORS_ORIGINS=http://localhost:3000,https://seo.geekatyourspot.com

# Environment (Development or Production)
ASPNETCORE_ENVIRONMENT=Development

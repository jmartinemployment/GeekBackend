# GeekRepository
DATABASE_URL=postgresql://user:password@localhost:5432/geekbackend
# Optional runtime-only role for geek_seo (migrations always use DATABASE_URL)
# GEEK_SEO_DATABASE_URL=postgresql://geekseo_app:password@host:5432/postgres
# GEEK_SEO_ENCRYPTION_KEY=<base64-32-byte-key>  # WordPress credentials at rest
# Deprecated — Development/integration tests only; production uses OAuth (see docs/geekrepository-oauth-access.md)
# REPO_API_KEY=local-bootstrap-only
GEEK_API_CLIENT_SECRET=change-me-geekapi-client-secret
GEEK_SEO_BACKEND_CLIENT_SECRET=change-me-geekseo-backend-secret

# GeekAPI
PORT=8080
ASPNETCORE_ENVIRONMENT=Development
AUTH_SERVER_URL=https://api.geekatyourspot.com
REPO_URL=http://localhost:5050
GEEK_BACKEND_API_KEY=change-me-api-key
GEEK_WEBSITE_CLIENT_SECRET=change-me-website-secret
GEEK_RESOURCE_SERVER_SECRET=change-me-resource-secret
CORS_ORIGINS=http://localhost:3000,https://seo.geekatyourspot.com,http://127.0.0.1

# Production signing (GeekAPI only)
OPENIDDICT_SIGNING_CERT=
OPENIDDICT_SIGNING_CERT_PASSWORD=

# Optional
BCRYPT_WORK_FACTOR=12

# Integration tests
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/geekbackend_test
TEST_REPO_URL=http://127.0.0.1:5050
